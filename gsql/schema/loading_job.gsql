  DEFINE FILENAME f_postcode        = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/postcode.csv";
  DEFINE FILENAME f_name_mh         = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/name_minhash.csv";
  DEFINE FILENAME f_address_mh      = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/address_minhash.csv";
  DEFINE FILENAME f_street_mh       = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/street_minhash.csv";

  DEFINE FILENAME f_has_account     = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_ACCOUNT.csv";
  DEFINE FILENAME f_has_phone       = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_PHONE.csv";
  DEFINE FILENAME f_has_email       = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_EMAIL.csv";
  DEFINE FILENAME f_has_used        = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_USED.csv";
  DEFINE FILENAME f_has_ip          = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_IP.csv";
  DEFINE FILENAME f_has_name        = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_NAME.csv";
  DEFINE FILENAME f_has_birthdate   = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_BIRTHDATE.csv";
  DEFINE FILENAME f_has_street_addr = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_STREET_ADDRESS.csv";
  DEFINE FILENAME f_has_city        = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_CITY.csv";
  DEFINE FILENAME f_has_state       = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_STATE.csv";
  DEFINE FILENAME f_has_postcode    = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_POSTCODE.csv";
  DEFINE FILENAME f_has_name_mh     = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_NAME_MINHASH.csv";
  DEFINE FILENAME f_has_address_mh  = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_ADDRESS_MINHASH.csv";
  DEFINE FILENAME f_has_street_mh   = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/HAS_STREET_MINHASH.csv";

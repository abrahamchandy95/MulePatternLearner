CREATE LOADING JOB load_all FOR GRAPH Mule_Pattern_Learner {

  DEFINE FILENAME f_accounts        = "/home/tigergraph/tigergraph/data/gui/loading_data/abraham.chandy@tigergraph.com/accountnumber.csv";
